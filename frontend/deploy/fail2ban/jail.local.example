[DEFAULT]
bantime = 1h
findtime = 10m
maxretry = 5
backend = systemd
banaction = ufw

[sshd]
enabled = true
port = ssh
logpath = %(sshd_log)s
maxretry = 3
bantime = 24h
findtime = 10m

# Ban clients repeatedly hitting nginx auth/forbidden/rate-limited responses.
[nginx-http-auth]
enabled = true
port = http,https
logpath = /var/log/nginx/*error*.log
maxretry = 3

[nginx-limit-req]
enabled = true
port = http,https
logpath = /var/log/nginx/*error*.log
maxretry = 10
findtime = 10m
bantime = 1h
