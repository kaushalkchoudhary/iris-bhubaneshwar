ENV=production
PORT=3001
JWT_SECRET=replace-with-strong-random-secret
WASENDER_API_TOKEN=replace-with-wasender-api-token
DATABASE_URL=postgresql://iris:iris_dev_password@localhost:5433/irisdrone?sslmode=disable
FRS_DATABASE_URL=postgresql://iris:iris_dev_password@localhost:5434/irisfrs?sslmode=disable
NATS_PORT=4233

# Optional: bootstrap console accounts (admin/operator) on server start.
# Set these if you need to recover access (e.g., no users exist yet or roles/passwords are wrong).
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_OPERATOR_EMAIL=
BOOTSTRAP_OPERATOR_PASSWORD=
# BOOTSTRAP_FORCE=1

# JWT session TTL (used for "active session" display in the Operator Access admin page).
# Changing this will affect how long the UI considers an operator "logged in" after LastLogin.
JWT_TTL_HOURS=24

# Server-side IP geolocation for audit UI (Operator Access page).
# Derived from the operator's source public IP at login time (approximate).
#
# Options:
# - GEOIP_PROVIDER=ipapi   (no token; subject to third-party rate limits)
# - GEOIP_PROVIDER=ipinfo  (requires GEOIP_TOKEN)
#
# If unset, GeoIP enrichment is disabled and the UI will show "-" for location fields.
GEOIP_PROVIDER=ipapi
# GEOIP_PROVIDER=ipinfo
# GEOIP_TOKEN=replace_with_ipinfo_token
GEOIP_TIMEOUT_MS=1500
GEOIP_CACHE_TTL_MINUTES=1440
