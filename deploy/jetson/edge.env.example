# Central control-plane server URL (backend host, not frontend port).
EDGE_SERVER_URL=http://10.10.0.1:3002
EDGE_GATEWAY_BIND=127.0.0.1:3900
EDGE_GATEWAY_URL=http://127.0.0.1:3900

# One-time registration token generated by admin UI (Settings -> Workers -> Tokens).
EDGE_REGISTRATION_TOKEN=

# Device identity shown in the central UI.
EDGE_DEVICE_NAME=jetson-01
EDGE_DEVICE_IP=
EDGE_DEVICE_MAC=
EDGE_DEVICE_MODEL=Jetson Orin Nano
EDGE_DEVICE_VERSION=1.0.0

# Runtime paths
EDGE_STATE_PATH=/var/lib/iris-edge/state.json
EDGE_LOG_DIR=/var/log/iris-edge
EDGE_INFERENCE_ROOT=/opt/iris-edge/inference-backend
EDGE_PYTHON_BIN=/opt/iris-edge/.venv/bin/python
INSIGHTFACE_HOME=/opt/iris-edge/.insightface

# Polling and retry behavior
EDGE_REQUEST_TIMEOUT_SEC=15
EDGE_HEARTBEAT_INTERVAL_SEC=5
EDGE_CONFIG_POLL_INTERVAL_SEC=10
EDGE_RETRY_DELAY_SEC=5

# Optional fallback for sites that use approval flow instead of registration token.
EDGE_ALLOW_APPROVAL_FLOW=0
EDGE_APPROVAL_POLL_INTERVAL_SEC=5
EDGE_APPROVAL_TIMEOUT_SEC=1800

# FRS-only mode: start only frs-analytics, skip ANPR/crowd/crowd-flow entirely.
# Set to 0 to revert to start_all_inference.py with per-module toggles below.
EDGE_FRS_ONLY=1

# Module toggles — only used when EDGE_FRS_ONLY=0.
EDGE_ENABLE_ANPR=0
EDGE_ENABLE_CROWD=0
EDGE_ENABLE_CROWD_FLOW=0
EDGE_ENABLE_FRS=1

# Force API-driven distributed behavior.
INFERENCE_STRICT_API_CONFIG=1
FRS_FORCE_API=1
